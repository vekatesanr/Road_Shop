# .env.example

# If you choose to upgrade to OpenWeatherMap (optional, Open-Meteo is default)
OWM_API_KEY=your_openweathermap_api_key_here

# Flask Environment (development or production)
FLASK_ENV=production

# Required for Render/Cloud Deployments
# Paste the entire JSON string of your Google service account credentials here
# Example: GOOGLE_CREDENTIALS_JSON={"type": "service_account", "project_id": "...", ...}
GOOGLE_CREDENTIALS_JSON=
